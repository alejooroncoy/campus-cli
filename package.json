{
  "name": "campus-cli",
  "version": "1.0.0",
  "description": "CLI/MCP no oficial para el campus universitario (Blackboard, Canvas, Moodle...) — acceso desde la terminal y MCP para IA",
  "main": "run.js",
  "bin": {
    "campus": "run.js",
    "campus-cli": "run.js",
    "blackboard": "run.js",
    "blackboard-upc": "run.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "postinstall": "playwright install chromium || true"
  },
  "keywords": [
    "campus",
    "blackboard",
    "canvas",
    "moodle",
    "upc",
    "aula-virtual",
    "cli",
    "mcp",
    "claude",
    "lms",
    "peru"
  ],
  "author": "Alejandro Oroncoy",
  "homepage": "https://github.com/alejooroncoy/campus-cli",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alejooroncoy/campus-cli.git"
  },
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0",
    "@types/inquirer": "^9.0.9",
    "@types/node": "^22.0.0",
    "axios": "^1.7.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "form-data": "^4.0.5",
    "inquirer": "^10.1.0",
    "ora": "^8.1.0",
    "playwright": "^1.47.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "zod": "^4.3.6"
  }
